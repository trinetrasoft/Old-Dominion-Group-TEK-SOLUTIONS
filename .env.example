# ODG Operations Platform configuration
# For local development, NODE_ENV=development is recommended.
NODE_ENV=development
PORT=8080

# REQUIRED in production: 64+ char random strings. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In development, weak placeholders are ignored and ephemeral secrets are generated.
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# SQLite database file path
DATABASE_PATH=./data/odg.db

# Comma-separated allowed CORS origins (leave empty for same-origin only)
CORS_ORIGINS=

# Set to 1 on first boot to create the default admin (admin@odg.example / see seed output)
SEED_ON_BOOT=0
